# Copy this file to .env and fill in real values. .env is git-ignored.

# SQL Server `sa` password. Must satisfy SQL Server complexity rules:
# 8+ chars, at least 3 of [uppercase, lowercase, digit, symbol].
MSSQL_SA_PASSWORD=

# RabbitMQ credentials (local dev message broker).
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# HMAC-SHA256 signing key shared by Identity (issues JWTs) and Order/Inventory
# (validate JWTs). Base64-encoded random 256-bit value recommended.
JWT_SIGNING_KEY=

# Redis password (--requirepass).
REDIS_PASSWORD=
