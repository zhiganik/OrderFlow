# Copy this file to .env and fill in real values. .env is git-ignored.

# SQL Server `sa` password. Must satisfy SQL Server complexity rules:
# 8+ chars, at least 3 of [uppercase, lowercase, digit, symbol].
MSSQL_SA_PASSWORD=

# RabbitMQ credentials (local dev message broker).
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# HMAC-SHA256 signing key shared by Identity (issues JWTs) and Order/Inventory
# (validate JWTs). Base64-encoded random 256-bit value recommended.
JWT_SIGNING_KEY=

# Redis password (--requirepass).
REDIS_PASSWORD=

# OTLP/HTTP logs endpoint of your Seq instance (Seq runs outside this compose
# file). If Seq runs on the host while services run in containers, use
# http://host.docker.internal:5341/ingest/otlp/v1/logs.
SEQ_ENDPOINT=

# Seq ingestion API key, sent as the X-Seq-ApiKey header. Leave blank if your
# Seq instance accepts anonymous ingestion.
SEQ_API_KEY=
